{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/consolidation-report.schema.json",
    "title": "ConsolidationReport",
    "description": "Merged output schema combining all PreProcessing and Consolidation step outputs. Contains the reference document structure, step-specific analysis results, and consolidation data (e.g. open points gap analysis).",
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "chapterId": {
            "type": "string",
            "description": "Unique ID of a chapter."
        },
        "sectionId": {
            "type": "string",
            "description": "Unique ID of a section."
        }
    },
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Optional ID of the document."
        },
        "chapters": {
            "type": "array",
            "description": "Catalog of all chapters (chapter headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId"
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter (Heading 1)."
                    }
                },
                "required": [
                    "chapter_id",
                    "chapter_heading"
                ]
            }
        },
        "sections": {
            "type": "array",
            "description": "Catalog of all sections (section headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "section_id": {
                        "$ref": "#/$defs/sectionId"
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section (Heading 2/3)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Reference to the parent chapter."
                    }
                },
                "required": [
                    "section_id",
                    "section_heading",
                    "chapter_id"
                ]
            }
        },
        "aspects": {
            "type": "array",
            "description": "Semantic aspects/topics with optional references to chapter and/or section.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "Unique ID of the aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Name of the aspect (e.g. topic/semantic label)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Optional reference to a chapter this aspect applies to."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Optional reference to a section this aspect applies to."
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Optional confidence score for the semantic assignment (0–1)."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page reference where the aspect was found, extracted from <!-- PageNumber=\"Page X of Y\" --> markers in the source document."
                    }
                },
                "required": [
                    "aspect_id",
                    "label"
                ]
            }
        },
        "executive_summary": {
            "type": "string",
            "description": "A concise executive summary of the tender document, maximum 10 lines. Captures the core objective, scope, key requirements, and expected outcomes."
        },
        "key_topics": {
            "type": "array",
            "description": "List of the main topics or themes identified in the document (5-10 short phrases).",
            "items": {
                "type": "string"
            }
        },
        "client_context": {
            "type": "object",
            "description": "Extracted client context forming the semantic bridge for downstream processing steps.",
            "additionalProperties": false,
            "properties": {
                "industry": {
                    "type": "string",
                    "description": "The client's industry sector (e.g., 'Automotive', 'Financial Services', 'Public Sector')."
                },
                "current_systems": {
                    "type": "array",
                    "description": "List of existing systems, platforms, or technologies the client currently uses.",
                    "items": {
                        "type": "string"
                    }
                },
                "pain_points": {
                    "type": "array",
                    "description": "Key challenges, problems, or pain points the client faces.",
                    "items": {
                        "type": "string"
                    }
                },
                "strategic_goals": {
                    "type": "array",
                    "description": "Strategic objectives or goals the client wants to achieve.",
                    "items": {
                        "type": "string"
                    }
                },
                "aspect_ids": {
                    "type": "array",
                    "description": "List of aspect IDs from the document classification that are relevant to this client context. Used for cross-referencing with the Overview step output.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "industry",
                "current_systems",
                "pain_points",
                "strategic_goals",
                "aspect_ids"
            ]
        },
        "contains_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains functional requirements."
        },
        "contains_non_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains non-functional requirements."
        },
        "functional_requirements": {
            "type": "array",
            "description": "Extracted functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. FR-001)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the functional requirement."
                    },
                    "priority": {
                        "type": "string",
                        "enum": [
                            "must",
                            "should",
                            "nice-to-have"
                        ],
                        "description": "Priority level of the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "description",
                    "priority",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "non_functional_requirements": {
            "type": "array",
            "description": "Extracted non-functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. NFR-001)."
                    },
                    "category": {
                        "type": "string",
                        "description": "Category of the NFR (e.g. Performance, Security, Availability)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the non-functional requirement."
                    },
                    "measurable_target": {
                        "type": "string",
                        "description": "Measurable target or metric for the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "category",
                    "description",
                    "measurable_target",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "contains_formal_requirements": {
            "type": "boolean",
            "description": "Whether the document contains formal proposal requirements."
        },
        "formal_requirements": {
            "type": "array",
            "description": "Extracted formal/procedural requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. FORM-001)."
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "Submission",
                            "Format",
                            "Deadline",
                            "Eligibility",
                            "Scope",
                            "Legal",
                            "Pricing",
                            "Other"
                        ],
                        "description": "Category of the formal requirement."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the formal requirement."
                    },
                    "binding": {
                        "type": "boolean",
                        "description": "Whether this requirement is mandatory (true) or optional/recommended (false)."
                    },
                    "deadline": {
                        "type": "string",
                        "description": "Specific deadline if mentioned, otherwise 'not specified'."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "category",
                    "description",
                    "binding",
                    "deadline",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "total_aspects": {
            "type": "integer",
            "description": "Total number of aspects in the consolidated input."
        },
        "covered_aspects": {
            "type": "integer",
            "description": "Number of aspects that have at least one requirement mapped."
        },
        "uncovered_aspects": {
            "type": "integer",
            "description": "Number of aspects with no requirement mapped."
        },
        "coverage_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Ratio of covered aspects to total aspects (0.0–1.0)."
        },
        "open_points": {
            "type": "array",
            "description": "List of aspects that have no requirements mapped to them.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "ID of the uncovered aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Label/name of the uncovered aspect."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Chapter ID the aspect belongs to."
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter for readability."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Section ID the aspect belongs to."
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section for readability."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Brief assessment why this aspect may have been missed or why it might not need a requirement."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "high",
                            "medium",
                            "low"
                        ],
                        "description": "How critical this gap is: high = likely missing requirement, medium = might be implicit, low = informational aspect unlikely to need a requirement."
                    }
                },
                "required": [
                    "aspect_id",
                    "label",
                    "chapter_heading",
                    "section_heading",
                    "reason",
                    "severity"
                ]
            }
        },
        "constraints": {
            "type": "object",
            "description": "Extracted project constraints covering budget, timeline, technical, and organisational boundaries.",
            "additionalProperties": false,
            "properties": {
                "budget": {
                    "type": "object",
                    "description": "Budget constraints mentioned in the document.",
                    "additionalProperties": false,
                    "properties": {
                        "amount": {
                            "type": "string",
                            "description": "Budget amount as stated in the document (e.g., '500.000 EUR', '2 Mio. CHF'). Use 'not specified' if no amount is given."
                        },
                        "currency": {
                            "type": "string",
                            "description": "Currency code (e.g., 'EUR', 'CHF', 'USD'). Use 'unknown' if not determinable."
                        },
                        "flexibility": {
                            "type": "string",
                            "enum": ["fixed", "indicative", "unknown"],
                            "description": "Whether the budget is a hard cap ('fixed'), a rough estimate ('indicative'), or not determinable ('unknown')."
                        },
                        "aspect_ids": {
                            "type": "array",
                            "description": "Aspect IDs from the aspects array that relate to budget information.",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "required": ["amount", "currency", "flexibility", "aspect_ids"]
                },
                "timeline": {
                    "type": "object",
                    "description": "Timeline constraints and milestones.",
                    "additionalProperties": false,
                    "properties": {
                        "go_live": {
                            "type": "string",
                            "description": "Target go-live or completion date (e.g., '2025-Q4', '01.01.2026'). Use 'not specified' if not stated."
                        },
                        "key_milestones": {
                            "type": "array",
                            "description": "Key milestones or deadlines mentioned in the document.",
                            "items": {
                                "type": "string"
                            }
                        },
                        "aspect_ids": {
                            "type": "array",
                            "description": "Aspect IDs from the aspects array that relate to timeline information.",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "required": ["go_live", "key_milestones", "aspect_ids"]
                },
                "technical": {
                    "type": "array",
                    "description": "Technical constraints or restrictions (e.g., 'must run on Azure', 'Java 17 required', 'no cloud hosting allowed').",
                    "items": {
                        "type": "string"
                    }
                },
                "organisational": {
                    "type": "array",
                    "description": "Organisational constraints (e.g., 'team must be on-site 3 days/week', 'ISO 27001 certification required', 'German-speaking project lead mandatory').",
                    "items": {
                        "type": "string"
                    }
                },
                "technical_aspect_ids": {
                    "type": "array",
                    "description": "Aspect IDs from the aspects array that relate to technical constraints.",
                    "items": {
                        "type": "string"
                    }
                },
                "organisational_aspect_ids": {
                    "type": "array",
                    "description": "Aspect IDs from the aspects array that relate to organisational constraints.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": ["budget", "timeline", "technical", "organisational", "technical_aspect_ids", "organisational_aspect_ids"]
        },
        "errors": {
            "type": "array",
            "description": "Error block for validation or processing errors.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Technical error code."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ],
                        "description": "Severity level of the error."
                    },
                    "reference": {
                        "type": "object",
                        "description": "Optional reference to affected elements.",
                        "additionalProperties": false,
                        "properties": {
                            "chapter_id": {
                                "$ref": "#/$defs/chapterId"
                            },
                            "section_id": {
                                "$ref": "#/$defs/sectionId"
                            },
                            "aspect_id": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "code",
                    "message"
                ]
            }
        }
    },
    "required": [
        "chapters",
        "sections",
        "aspects",
        "executive_summary",
        "key_topics",
        "client_context",
        "constraints",
        "total_aspects",
        "covered_aspects",
        "uncovered_aspects",
        "coverage_ratio",
        "open_points"
    ]
}