{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/constraints.schema.json",
    "title": "Constraints",
    "description": "Extracted project constraints including budget, timeline, technical, and organisational boundaries.",
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "chapterId": {
            "type": "string",
            "description": "Unique ID of a chapter."
        },
        "sectionId": {
            "type": "string",
            "description": "Unique ID of a section."
        }
    },
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Optional ID of the document."
        },
        "chapters": {
            "type": "array",
            "description": "Catalog of all chapters (chapter headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId"
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter (Heading 1)."
                    }
                },
                "required": [
                    "chapter_id",
                    "chapter_heading"
                ]
            }
        },
        "sections": {
            "type": "array",
            "description": "Catalog of all sections (section headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "section_id": {
                        "$ref": "#/$defs/sectionId"
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section (Heading 2/3)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Reference to the parent chapter."
                    }
                },
                "required": [
                    "section_id",
                    "section_heading",
                    "chapter_id"
                ]
            }
        },
        "aspects": {
            "type": "array",
            "description": "Semantic aspects/topics with optional references to chapter and/or section.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "Unique ID of the aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Name of the aspect (e.g. topic/semantic label)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Optional reference to a chapter this aspect applies to."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Optional reference to a section this aspect applies to."
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Optional confidence score for the semantic assignment (0–1)."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page reference where the aspect was found, extracted from <!-- PageNumber=\"Page X of Y\" --> markers in the source document."
                    }
                },
                "required": [
                    "aspect_id",
                    "label"
                ]
            }
        },
        "constraints": {
            "type": "object",
            "description": "Extracted project constraints covering budget, timeline, technical, and organisational boundaries.",
            "additionalProperties": false,
            "properties": {
                "budget": {
                    "type": "object",
                    "description": "Budget constraints mentioned in the document.",
                    "additionalProperties": false,
                    "properties": {
                        "amount": {
                            "type": "string",
                            "description": "Budget amount as stated in the document (e.g., '500.000 EUR', '2 Mio. CHF'). Use 'not specified' if no amount is given."
                        },
                        "currency": {
                            "type": "string",
                            "description": "Currency code (e.g., 'EUR', 'CHF', 'USD'). Use 'unknown' if not determinable."
                        },
                        "flexibility": {
                            "type": "string",
                            "enum": ["fixed", "indicative", "unknown"],
                            "description": "Whether the budget is a hard cap ('fixed'), a rough estimate ('indicative'), or not determinable ('unknown')."
                        },
                        "aspect_ids": {
                            "type": "array",
                            "description": "Aspect IDs from the aspects array that relate to budget information.",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "required": ["amount", "currency", "flexibility", "aspect_ids"]
                },
                "timeline": {
                    "type": "object",
                    "description": "Timeline constraints and milestones.",
                    "additionalProperties": false,
                    "properties": {
                        "go_live": {
                            "type": "string",
                            "description": "Target go-live or completion date (e.g., '2025-Q4', '01.01.2026'). Use 'not specified' if not stated."
                        },
                        "key_milestones": {
                            "type": "array",
                            "description": "Key milestones or deadlines mentioned in the document.",
                            "items": {
                                "type": "string"
                            }
                        },
                        "aspect_ids": {
                            "type": "array",
                            "description": "Aspect IDs from the aspects array that relate to timeline information.",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "required": ["go_live", "key_milestones", "aspect_ids"]
                },
                "technical": {
                    "type": "array",
                    "description": "Technical constraints or restrictions (e.g., 'must run on Azure', 'Java 17 required', 'no cloud hosting allowed').",
                    "items": {
                        "type": "string"
                    }
                },
                "organisational": {
                    "type": "array",
                    "description": "Organisational constraints (e.g., 'team must be on-site 3 days/week', 'ISO 27001 certification required', 'German-speaking project lead mandatory').",
                    "items": {
                        "type": "string"
                    }
                },
                "technical_aspect_ids": {
                    "type": "array",
                    "description": "Aspect IDs from the aspects array that relate to technical constraints.",
                    "items": {
                        "type": "string"
                    }
                },
                "organisational_aspect_ids": {
                    "type": "array",
                    "description": "Aspect IDs from the aspects array that relate to organisational constraints.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": ["budget", "timeline", "technical", "organisational", "technical_aspect_ids", "organisational_aspect_ids"]
        },
        "errors": {
            "type": "array",
            "description": "Error block for validation or processing errors.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Technical error code."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ],
                        "description": "Severity level of the error."
                    },
                    "reference": {
                        "type": "object",
                        "description": "Optional reference to affected elements.",
                        "additionalProperties": false,
                        "properties": {
                            "chapter_id": {
                                "$ref": "#/$defs/chapterId"
                            },
                            "section_id": {
                                "$ref": "#/$defs/sectionId"
                            },
                            "aspect_id": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "code",
                    "message"
                ]
            }
        }
    },
    "required": [
        "chapters",
        "sections",
        "aspects",
        "constraints"
    ]
}
