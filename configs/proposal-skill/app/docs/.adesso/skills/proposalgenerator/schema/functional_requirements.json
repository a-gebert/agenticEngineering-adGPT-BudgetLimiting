{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/document-classification.schema.json",
    "title": "DocumentClassification",
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "chapterId": {
            "type": "string",
            "description": "Unique ID of a chapter."
        },
        "sectionId": {
            "type": "string",
            "description": "Unique ID of a section."
        }
    },
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Optional ID of the document."
        },
        "chapters": {
            "type": "array",
            "description": "Catalog of all chapters (chapter headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId"
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter (Heading 1)."
                    }
                },
                "required": [
                    "chapter_id",
                    "chapter_heading"
                ]
            }
        },
        "sections": {
            "type": "array",
            "description": "Catalog of all sections (section headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "section_id": {
                        "$ref": "#/$defs/sectionId"
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section (Heading 2/3)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Reference to the parent chapter."
                    }
                },
                "required": [
                    "section_id",
                    "section_heading",
                    "chapter_id"
                ]
            }
        },
        "aspects": {
            "type": "array",
            "description": "Semantic aspects/topics with optional references to chapter and/or section.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "Unique ID of the aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Name of the aspect (e.g. topic/semantic label)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Optional reference to a chapter this aspect applies to."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Optional reference to a section this aspect applies to."
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Optional confidence score for the semantic assignment (0–1)."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page reference where the aspect was found, extracted from <!-- PageNumber=\"Page X of Y\" --> markers in the source document."
                    }
                },
                "required": [
                    "aspect_id",
                    "label"
                ]
            }
        },
        "contains_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains functional requirements."
        },
        "contains_non_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains non-functional requirements."
        },
        "functional_requirements": {
            "type": "array",
            "description": "Extracted functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Internal analysis identifier for the requirement (e.g. FR-001). NOT client-facing — assigned by this step, unknown to the tender author."
                    },
                    "client_ref": {
                        "type": "string",
                        "description": "The tender's OWN native identifier for this requirement as printed in the source document (e.g. a User-Story ID, requirement number, or section/table reference like 'US-14', 'Req 3.2.1'). Copy verbatim if the document labels the requirement; omit if the tender gives no native identifier."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the functional requirement."
                    },
                    "priority": {
                        "type": "string",
                        "enum": ["must", "should", "nice-to-have"],
                        "description": "Priority level of the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": ["id", "description", "priority", "source_section", "source_file", "source_page", "aspect_id"]
            }
        },
        "non_functional_requirements": {
            "type": "array",
            "description": "Extracted non-functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Internal analysis identifier for the requirement (e.g. NFR-001). NOT client-facing — assigned by this step, unknown to the tender author."
                    },
                    "client_ref": {
                        "type": "string",
                        "description": "The tender's OWN native identifier for this requirement as printed in the source document (e.g. a User-Story ID, requirement number, or section/table reference). Copy verbatim if the document labels the requirement; omit if the tender gives no native identifier."
                    },
                    "category": {
                        "type": "string",
                        "description": "Category of the NFR (e.g. Performance, Security, Availability)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the non-functional requirement."
                    },
                    "measurable_target": {
                        "type": "string",
                        "description": "Measurable target or metric for the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": ["id", "category", "description", "measurable_target", "source_section", "source_file", "source_page", "aspect_id"]
            }
        },
        "errors": {
            "type": "array",
            "description": "Error block for validation or processing errors.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Technical error code."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ],
                        "description": "Severity level of the error."
                    },
                    "reference": {
                        "type": "object",
                        "description": "Optional reference to affected elements.",
                        "additionalProperties": false,
                        "properties": {
                            "chapter_id": {
                                "$ref": "#/$defs/chapterId"
                            },
                            "section_id": {
                                "$ref": "#/$defs/sectionId"
                            },
                            "aspect_id": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "code",
                    "message"
                ]
            }
        }
    },
    "required": [
        "chapters",
        "sections",
        "aspects"
    ]
}
