{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/open-points.schema.json",
    "title": "OpenPoints",
    "description": "Lists aspects from the document structure that have no requirement mapped to them. Identifies gaps in the requirements extraction.",
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "chapterId": {
            "type": "string",
            "description": "Unique ID of a chapter."
        },
        "sectionId": {
            "type": "string",
            "description": "Unique ID of a section."
        }
    },
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Optional ID of the document."
        },
        "chapters": {
            "type": "array",
            "description": "Catalog of all chapters (chapter headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId"
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter (Heading 1)."
                    }
                },
                "required": [
                    "chapter_id",
                    "chapter_heading"
                ]
            }
        },
        "sections": {
            "type": "array",
            "description": "Catalog of all sections (section headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "section_id": {
                        "$ref": "#/$defs/sectionId"
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section (Heading 2/3)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Reference to the parent chapter."
                    }
                },
                "required": [
                    "section_id",
                    "section_heading",
                    "chapter_id"
                ]
            }
        },
        "aspects": {
            "type": "array",
            "description": "Semantic aspects/topics with optional references to chapter and/or section.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "Unique ID of the aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Name of the aspect (e.g. topic/semantic label)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Optional reference to a chapter this aspect applies to."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Optional reference to a section this aspect applies to."
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Optional confidence score for the semantic assignment (0–1)."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page reference where the aspect was found, extracted from <!-- PageNumber=\"Page X of Y\" --> markers in the source document."
                    }
                },
                "required": [
                    "aspect_id",
                    "label"
                ]
            }
        },
        "total_aspects": {
            "type": "integer",
            "description": "Total number of aspects in the consolidated input."
        },
        "covered_aspects": {
            "type": "integer",
            "description": "Number of aspects that have at least one requirement mapped."
        },
        "uncovered_aspects": {
            "type": "integer",
            "description": "Number of aspects with no requirement mapped."
        },
        "coverage_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Ratio of covered aspects to total aspects (0.0–1.0)."
        },
        "open_points": {
            "type": "array",
            "description": "List of aspects that have no requirements mapped to them.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "ID of the uncovered aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Label/name of the uncovered aspect."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Chapter ID the aspect belongs to."
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter for readability."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Section ID the aspect belongs to."
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section for readability."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Brief assessment why this aspect may have been missed or why it might not need a requirement."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "high",
                            "medium",
                            "low"
                        ],
                        "description": "How critical this gap is: high = likely missing requirement, medium = might be implicit, low = informational aspect unlikely to need a requirement."
                    }
                },
                "required": [
                    "aspect_id",
                    "label",
                    "chapter_heading",
                    "section_heading",
                    "reason",
                    "severity"
                ]
            }
        },
        "errors": {
            "type": "array",
            "description": "Error block for validation or processing errors.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Technical error code."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ],
                        "description": "Severity level of the error."
                    },
                    "reference": {
                        "type": "object",
                        "description": "Optional reference to affected elements.",
                        "additionalProperties": false,
                        "properties": {
                            "chapter_id": {
                                "$ref": "#/$defs/chapterId"
                            },
                            "section_id": {
                                "$ref": "#/$defs/sectionId"
                            },
                            "aspect_id": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "code",
                    "message"
                ]
            }
        }
    },
    "required": [
        "chapters",
        "sections",
        "aspects",
        "total_aspects",
        "covered_aspects",
        "uncovered_aspects",
        "coverage_ratio",
        "open_points"
    ]
}
