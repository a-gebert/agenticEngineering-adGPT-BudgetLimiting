{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/preflight-report.schema.json",
    "title": "PreflightReport",
    "description": "Merged output schema combining all PreProcessing step outputs. Contains the reference document structure plus step-specific analysis results.",
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "chapterId": {
            "type": "string",
            "description": "Unique ID of a chapter."
        },
        "sectionId": {
            "type": "string",
            "description": "Unique ID of a section."
        }
    },
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Optional ID of the document."
        },
        "chapters": {
            "type": "array",
            "description": "Catalog of all chapters (chapter headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId"
                    },
                    "chapter_heading": {
                        "type": "string",
                        "description": "Heading of the chapter (Heading 1)."
                    }
                },
                "required": [
                    "chapter_id",
                    "chapter_heading"
                ]
            }
        },
        "sections": {
            "type": "array",
            "description": "Catalog of all sections (section headings).",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "section_id": {
                        "$ref": "#/$defs/sectionId"
                    },
                    "section_heading": {
                        "type": "string",
                        "description": "Heading of the section (Heading 2/3)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Reference to the parent chapter."
                    }
                },
                "required": [
                    "section_id",
                    "section_heading",
                    "chapter_id"
                ]
            }
        },
        "aspects": {
            "type": "array",
            "description": "Semantic aspects/topics with optional references to chapter and/or section.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "aspect_id": {
                        "type": "string",
                        "description": "Unique ID of the aspect."
                    },
                    "label": {
                        "type": "string",
                        "description": "Name of the aspect (e.g. topic/semantic label)."
                    },
                    "chapter_id": {
                        "$ref": "#/$defs/chapterId",
                        "description": "Optional reference to a chapter this aspect applies to."
                    },
                    "section_id": {
                        "$ref": "#/$defs/sectionId",
                        "description": "Optional reference to a section this aspect applies to."
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Optional confidence score for the semantic assignment (0–1)."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page reference where the aspect was found, extracted from <!-- PageNumber=\"Page X of Y\" --> markers in the source document."
                    }
                },
                "required": [
                    "aspect_id",
                    "label"
                ]
            }
        },
        "executive_summary": {
            "type": "string",
            "description": "A concise executive summary of the tender document, maximum 10 lines. Captures the core objective, scope, key requirements, and expected outcomes."
        },
        "key_topics": {
            "type": "array",
            "description": "List of the main topics or themes identified in the document (5-10 short phrases).",
            "items": {
                "type": "string"
            }
        },
        "client_context": {
            "type": "object",
            "description": "Extracted client context forming the semantic bridge for downstream processing steps.",
            "additionalProperties": false,
            "properties": {
                "industry": {
                    "type": "string",
                    "description": "The client's industry sector (e.g., 'Automotive', 'Financial Services', 'Public Sector')."
                },
                "current_systems": {
                    "type": "array",
                    "description": "List of existing systems, platforms, or technologies the client currently uses.",
                    "items": {
                        "type": "string"
                    }
                },
                "pain_points": {
                    "type": "array",
                    "description": "Key challenges, problems, or pain points the client faces.",
                    "items": {
                        "type": "string"
                    }
                },
                "strategic_goals": {
                    "type": "array",
                    "description": "Strategic objectives or goals the client wants to achieve.",
                    "items": {
                        "type": "string"
                    }
                },
                "aspect_ids": {
                    "type": "array",
                    "description": "List of aspect IDs from the document classification that are relevant to this client context. Used for cross-referencing with the Overview step output.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "industry",
                "current_systems",
                "pain_points",
                "strategic_goals",
                "aspect_ids"
            ]
        },
        "contains_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains functional requirements."
        },
        "contains_non_functional_requirements": {
            "type": "boolean",
            "description": "Whether the document contains non-functional requirements."
        },
        "functional_requirements": {
            "type": "array",
            "description": "Extracted functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. FR-001)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the functional requirement."
                    },
                    "priority": {
                        "type": "string",
                        "enum": [
                            "must",
                            "should",
                            "nice-to-have"
                        ],
                        "description": "Priority level of the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "description",
                    "priority",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "non_functional_requirements": {
            "type": "array",
            "description": "Extracted non-functional requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. NFR-001)."
                    },
                    "category": {
                        "type": "string",
                        "description": "Category of the NFR (e.g. Performance, Security, Availability)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the non-functional requirement."
                    },
                    "measurable_target": {
                        "type": "string",
                        "description": "Measurable target or metric for the requirement."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "category",
                    "description",
                    "measurable_target",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "contains_formal_requirements": {
            "type": "boolean",
            "description": "Whether the document contains formal proposal requirements."
        },
        "formal_requirements": {
            "type": "array",
            "description": "Extracted formal/procedural requirements from the document.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the requirement (e.g. FORM-001)."
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "Submission",
                            "Format",
                            "Deadline",
                            "Eligibility",
                            "Scope",
                            "Legal",
                            "Pricing",
                            "Other"
                        ],
                        "description": "Category of the formal requirement."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of the formal requirement."
                    },
                    "binding": {
                        "type": "boolean",
                        "description": "Whether this requirement is mandatory (true) or optional/recommended (false)."
                    },
                    "deadline": {
                        "type": "string",
                        "description": "Specific deadline if mentioned, otherwise 'not specified'."
                    },
                    "source_section": {
                        "type": "string",
                        "description": "Section heading where the requirement was found."
                    },
                    "source_file": {
                        "type": "string",
                        "description": "File name where the requirement was found."
                    },
                    "source_page": {
                        "type": "string",
                        "description": "Page number or reference where the requirement was found."
                    },
                    "aspect_id": {
                        "type": "string",
                        "description": "Reference to the related aspect in the aspects array."
                    }
                },
                "required": [
                    "id",
                    "category",
                    "description",
                    "binding",
                    "deadline",
                    "source_section",
                    "source_file",
                    "source_page",
                    "aspect_id"
                ]
            }
        },
        "constraints": {
            "type": "object",
            "description": "Extracted project constraints covering budget, timeline, technical, and organisational boundaries.",
            "additionalProperties": false,
            "properties": {
                "budget": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "amount": { "type": "string" },
                        "currency": { "type": "string" },
                        "flexibility": { "type": "string", "enum": ["fixed", "indicative", "unknown"] },
                        "aspect_ids": { "type": "array", "items": { "type": "string" } }
                    },
                    "required": ["amount", "currency", "flexibility", "aspect_ids"]
                },
                "timeline": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "go_live": { "type": "string" },
                        "key_milestones": { "type": "array", "items": { "type": "string" } },
                        "aspect_ids": { "type": "array", "items": { "type": "string" } }
                    },
                    "required": ["go_live", "key_milestones", "aspect_ids"]
                },
                "technical": { "type": "array", "items": { "type": "string" } },
                "organisational": { "type": "array", "items": { "type": "string" } },
                "technical_aspect_ids": { "type": "array", "items": { "type": "string" } },
                "organisational_aspect_ids": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["budget", "timeline", "technical", "organisational", "technical_aspect_ids", "organisational_aspect_ids"]
        },
        "errors": {
            "type": "array",
            "description": "Error block for validation or processing errors.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Technical error code."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message."
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ],
                        "description": "Severity level of the error."
                    },
                    "reference": {
                        "type": "object",
                        "description": "Optional reference to affected elements.",
                        "additionalProperties": false,
                        "properties": {
                            "chapter_id": {
                                "$ref": "#/$defs/chapterId"
                            },
                            "section_id": {
                                "$ref": "#/$defs/sectionId"
                            },
                            "aspect_id": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "code",
                    "message"
                ]
            }
        }
    },
    "required": [
        "chapters",
        "sections",
        "aspects",
        "executive_summary",
        "key_topics",
        "client_context",
        "constraints"
    ]
}